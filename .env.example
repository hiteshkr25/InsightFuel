# Ingestion API Settings
INGESTION_PORT=3001
INGESTION_HOST=0.0.0.0

# Query API Settings
QUERY_PORT=3002
QUERY_HOST=0.0.0.0

# API Gateway / BFF Settings
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# PostgreSQL Settings
POSTGRES_USER=insightfuel
POSTGRES_PASSWORD=insightfuel_secure_pass
POSTGRES_DB=insightfuel_metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://insightfuel:insightfuel_secure_pass@localhost:5432/insightfuel_metadata?schema=public

# ClickHouse Settings
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=insightfuel_clickhouse_pass
CLICKHOUSE_DB=insightfuel_events

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=insightfuel_redis_pass

# Kafka / Redpanda Settings
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=insightfuel-platform
KAFKA_TOPIC_RAW_EVENTS=raw-events

# Demo Mode Settings
DEMO_MODE=false

